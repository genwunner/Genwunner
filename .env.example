# ============================================================
# SUPABASE
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# RESEND (Email)
# Get from: https://resend.com/api-keys
# Verify your domain at: https://resend.com/domains
# ============================================================
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# SHOPIFY STOREFRONT API
# Get from: Shopify Admin → Apps → Develop apps → Storefront API
# ============================================================
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token

# ============================================================
# LAYLO (Fan SMS / Presave Campaigns)
# Get from: https://laylo.com → your account → Integrations
# ============================================================
NEXT_PUBLIC_LAYLO_EMBED_ID=your-laylo-id
LAYLO_WEBHOOK_SECRET=make-up-a-long-random-string

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Genwunner

# ============================================================
# CONTENT AUTOMATION (add when ready)
# ============================================================
# INSTAGRAM_ACCESS_TOKEN=
# TWITTER_BEARER_TOKEN=
# TIKTOK_CLIENT_KEY=
# YOUTUBE_API_KEY=

# ============================================================
# CRON (Vercel Cron Jobs)
# Generate with: openssl rand -hex 32
# Add same value to Vercel → Settings → Environment Variables
# ============================================================
CRON_SECRET=your-long-random-secret
